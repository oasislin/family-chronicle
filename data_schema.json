            "description": "王建国与李梅结婚（二婚）",
            "location": "县城",
            "participants": [
              {"person_id": "person_002", "role": "新郎"},
              {"person_id": "person_003", "role": "新娘"}
            ],
            "source": "父亲口述",
            "confidence": "high"
          },
          {
            "id": "event_002",
            "type": "recognition",
            "date": "1996",
            "date_accuracy": "year",
            "description": "王建国认赵大爷为干爹",
            "location": "王家村",
            "participants": [
              {"person_id": "person_002", "role": "干儿子"},
              {"person_id": "person_004", "role": "干爹"}
            ],
            "source": "父亲口述",
            "confidence": "medium"
          },
          {
            "id": "event_003",
            "type": "birth",
            "date": "1996",
            "date_accuracy": "year",
            "description": "小芳出生",
            "participants": [
              {"person_id": "person_005", "role": "新生儿"},
              {"person_id": "person_002", "role": "父亲"},
              {"person_id": "person_003", "role": "母亲"}
            ],
            "source": "父亲口述",
            "confidence": "high"
          }
        ]
      },
      "relationships": [
        {
          "id": "rel_001",
          "person1_id": "person_001",
          "person2_id": "person_002",
          "type": "parent_child",
          "subtype": "father",
          "attributes": {"birth_order": "老二"}
        },
        {
          "id": "rel_002",
          "person1_id": "person_002",
          "person2_id": "person_003",
          "type": "spouse",
          "start_date": "1995-09-15",
          "attributes": {"marriage_number": 2},
          "event_id": "event_001"
        },
        {
          "id": "rel_003",
          "person1_id": "person_002",
          "person2_id": "person_004",
          "type": "godparent_godchild",
          "subtype": "godfather_godson",
          "start_date": "1996",
          "event_id": "event_002"
        },
        {
          "id": "rel_004",
          "person1_id": "person_002",
          "person2_id": "person_005",
          "type": "parent_child",
          "subtype": "father",
          "event_id": "event_003"
        },
        {
          "id": "rel_005",
          "person1_id": "person_003",
          "person2_id": "person_005",
          "type": "parent_child",
          "subtype": "mother",
          "event_id": "event_003"
        }
      ]
    },
