# ===== AI 服务配置 =====
# 选择AI服务提供商: deepseek / zhipu / openai / anthropic
AI_PROVIDER=deepseek

# 华为 ModelArts DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.modelarts-maas.com/openai/v1
DEEPSEEK_MODEL=deepseekV3-2

# 智谱 GLM（可选）
ZHIPU_API_KEY=your-zhipu-api-key-here

# OpenAI（可选）
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude（可选）
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ===== 应用配置 =====
SECRET_KEY=change-me-to-a-random-string
PORT=8000
DEBUG=False

# 数据目录（绝对路径或相对于项目根目录的路径）
# 默认指向项目根目录下的 data/ 文件夹
# DATA_DIR=C:\path\to\your\data

# 日志配置
# LOG_FILE=C:\path\to\your\logs\app.log
LOG_LEVEL=INFO
